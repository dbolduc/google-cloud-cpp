prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib64
includedir=${prefix}/include

Name: Darren's OpenTelemetry Library - Common
Description: Darren's OpenTelemetry Library for testing
Requires: opentelemetry_version

Version: 1.9.1

Libs: -L${libdir} -lopentelemetry_common
Cflags: -I${includedir} -DHAVE_ABSEIL
